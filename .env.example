# ─────────────────────────────────────────────────────────────────
# AX 챔피언 운영봇 — 환경 변수 템플릿
# 실제 값은 backyard `환경 변수` 탭에 주입. 로컬 개발 시 `.env.local` 로 복사.
# ─────────────────────────────────────────────────────────────────

# ── Slack ──────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_AX_CHANNEL_ID=C0B1PCMEQBD
SLACK_ADMIN_USER_ID=U03EK844MU2
SLACK_AI_JUBJUB_CHANNEL_ID=

# ── Google Sheets ──────────────────────────────────────────────
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# JSON 키 파일 전체 내용을 그대로 (raw JSON) 주입.
#   cat service-account.json | pbcopy
GOOGLE_SERVICE_ACCOUNT_KEY=

# ── Postgres ───────────────────────────────────────────────────
# backyard postgresql 템플릿이 자동 주입. 로컬은 docker postgres 또는 supabase 등.
DATABASE_URL=postgres://user:pass@localhost:5432/ax_champion

# ── 운영 ──────────────────────────────────────────────────────
# true: 모든 발송이 운영진 본인 DM 으로만 (dry-run)
# false: 실제 채널/DM 발송
DRY_RUN=true

# 자동 cron 등록 여부.
#   false (기본): 자동 발화 X. 수동 트리거(/api/admin/cron/{A1|A3|A4})로만 발화.
#   true: KST 기준 Mon09 / Wed15 / Wed18 자동 발화.
# 5/11 이후에도 false 유지 권장 — 검증 끝난 시점에 운영진 결정으로 true 전환.
CRON_AUTO_ENABLED=false

# 수동 트리거 endpoint 인증 토큰. 16자 이상 임의 문자열.
# 생성 예시: openssl rand -hex 32
ADMIN_API_TOKEN=

TZ=Asia/Seoul
PROGRAM_START_DATE=2026-05-11
PROGRAM_WEEKS=9
